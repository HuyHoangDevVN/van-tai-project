{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Core.Sql": "Debug",
      "Core.Sql.Services.SshTunnelService": "Information",
      "Application": "Debug"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=127.0.0.1;Port=3306;Database=van_tai;User=root;Password=your_password_here;Pooling=true;MinimumPoolSize=5;MaximumPoolSize=100;ConnectionLifeTime=300;ConnectionTimeout=30;DefaultCommandTimeout=30;"
  },
  "SshTunnel": {
    "Enabled": false,
    "Host": "your-ssh-server.com",
    "Port": 22,
    "Username": "your_ssh_username",
    "Password": "",
    "PrivateKeyPath": "",
    "PrivateKeyPassphrase": "",
    "LocalPort": 13306,
    "RemoteMySqlHost": "127.0.0.1",
    "RemoteMySqlPort": 3306,
    "ConnectionTimeoutSeconds": 30,
    "HealthCheckIntervalSeconds": 30,
    "MaxRetryAttempts": 5,
    "RetryDelaySeconds": 5
  },
  "AdminAccess": {
    "Enabled": true,
    "RoleHeaderName": "X-User-Role",
    "ApiKeyHeaderName": "X-Admin-Key",
    "ApiKey": ""
  },
  "MaintenanceAlerts": {
    "WarningDays": 30
  },
  "AllowedHosts": "*"
}
